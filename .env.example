# --- Database (Neon Postgres) ---
# Get BOTH strings from neon.tech -> your project -> Connection Details.
#   Pooled  = the host WITH "-pooler" in it  (used by the app at runtime)
#   Direct  = the host WITHOUT "-pooler"     (used by db push / migrate / seed)
# You do NOT need Vercel to get these — Neon gives them to you directly.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Secret for signing JWTs — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# Where exercise images are served from. Options:
#  - free-exercise-db raw:  https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/
#  - your own R2 / Vercel Blob bucket base URL
#  - /exercises/  if you copy the images into Next.js /public
NEXT_PUBLIC_IMAGE_BASE="https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/"
# After uploading to R2 and enabling public access, change the line above to your
# bucket's public URL with a trailing slash, e.g. https://img.yourdomain.com/

# --- Cloudflare R2 (used only by scripts/upload-to-r2.mjs, not at runtime) ---
R2_ACCOUNT_ID="79fa21a90021aad8816a18bd2932f225"
R2_ACCESS_KEY_ID="b8b0b359f9db3d17c54b0172c811621c"
R2_SECRET_ACCESS_KEY="ec3d64075c4f6acc99fbfd0a561a0249c41279efb203357dcdef8e86bd4c2f32"
R2_BUCKET="forge-exercises"
R2_KEY_PREFIX=""
UPLOAD_DIR="./forge-workout/images"

